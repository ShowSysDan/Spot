# --- Database ---
# Shared Postgres instance; Spot uses an isolated schema (default: spot).
SPOT_DB_HOST=127.0.0.1
SPOT_DB_PORT=5432
SPOT_DB_NAME=shared
SPOT_DB_USER=spot_user
SPOT_DB_PASSWORD=changeme
SPOT_DB_SCHEMA=spot

# --- Web ---
SPOT_WEB_HOST=0.0.0.0
SPOT_WEB_PORT=6100

# --- Syslog ---
# Either a local socket (e.g. /dev/log) or host:port for a remote rsyslog/syslog-ng.
SPOT_SYSLOG_ADDRESS=/dev/log
SPOT_SYSLOG_FACILITY=local0
SPOT_LOG_LEVEL=INFO

# --- Misc ---
# Secret used by Flask sessions (no auth currently, but kept for flash messages).
SPOT_SECRET_KEY=please-change-me
# Comma-separated trusted ingest sources, or leave empty to allow any.
SPOT_INGEST_ALLOW=

# How often the retention janitor runs (seconds; minimum effective = 60).
SPOT_JANITOR_INTERVAL_SECONDS=3600

# Default retention applied to monitors that don't set their own (days).
# Leave blank to keep data forever unless a per-monitor policy exists.
SPOT_DEFAULT_RETENTION_DAYS=
